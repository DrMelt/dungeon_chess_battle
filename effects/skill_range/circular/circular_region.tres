code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_disabled, unshaded, shadows_disabled;

uniform vec4 ColorParameter : source_color = vec4(1.000000, 1.000000, 1.000000, 1.000000);
uniform sampler2D depth_tex_frg_3 : hint_depth_texture, repeat_disable, filter_nearest;
uniform float Near = 0.0;
uniform float Skill_Progress;
uniform sampler2D curve_frg_49 : repeat_disable;
uniform float Skill_Radian_To = 1.0;
uniform float Skill_Radian_From = -1.0;
uniform sampler2D normal_rough_tex_frg_16 : hint_normal_roughness_texture, repeat_disable, filter_nearest;



void fragment() {
// ColorParameter:15
	vec4 n_out15p0 = ColorParameter;


// Input:6
	mat4 n_out6p0 = MODEL_MATRIX;


// TransformFunc:4
	mat4 n_out4p0 = inverse(n_out6p0);


	vec3 n_out3p0;
// WorldPositionFromDepth:3
	{
		float __log_depth = textureLod(depth_tex_frg_3, SCREEN_UV, 0.0).x;
		vec4 __ndc = vec4(SCREEN_UV * 2.0 - 1.0, __log_depth, 1.0);
		vec4 __position_world = INV_VIEW_MATRIX * INV_PROJECTION_MATRIX * __ndc;
		__position_world.xyz /= __position_world.w;
		n_out3p0 = __position_world.xyz;
	}


// Input:14
	vec3 n_out14p0 = NODE_POSITION_WORLD;


// VectorOp:13
	vec3 n_out13p0 = n_out3p0 - n_out14p0;


// TransformVectorMult:7
	vec3 n_out7p0 = (n_out4p0 * vec4(n_out13p0, 0.0)).xyz;
	float n_out7p1 = n_out7p0.r;
	float n_out7p3 = n_out7p0.b;


// VectorCompose:11
	vec2 n_out11p0 = vec2(n_out7p1, n_out7p3);


// VectorOp:10
	vec2 n_in10p1 = vec2(0.50000, 0.50000);
	vec2 n_out10p0 = n_out11p0 + n_in10p1;


// VectorOp:21
	vec2 n_in21p1 = vec2(-0.50000, -0.50000);
	vec2 n_out21p0 = n_out10p0 + n_in21p1;


// VectorOp:22
	vec2 n_in22p1 = vec2(2.00000, 2.00000);
	vec2 n_out22p0 = n_out21p0 * n_in22p1;


// VectorLen:23
	float n_out23p0 = length(n_out22p0);


// FloatParameter:31
	float n_out31p0 = Near;


// FloatOp:52
	float n_out52p0 = n_out23p0 - n_out31p0;


// FloatConstant:32
	float n_out32p0 = 1.000000;


// FloatOp:54
	float n_out54p0 = n_out32p0 - n_out31p0;


// FloatOp:53
	float n_out53p0 = n_out52p0 / n_out54p0;


// FloatParameter:37
	float n_out37p0 = Skill_Progress;


// Compare:59
	bool n_out59p0 = n_out53p0 < n_out37p0;


// FloatOp:51
	float n_out51p0 = n_out53p0 - n_out37p0;


// FloatOp:57
	float n_in57p1 = 1.00000;
	float n_out57p0 = mod(n_out51p0, n_in57p1);


// FloatOp:60
	float n_out60p0 = (n_out59p0 ? 1.0 : 0.0) * n_out57p0;


// CurveTexture:49
	float n_out49p0 = texture(curve_frg_49, vec2(n_out60p0)).r;


// VectorDecompose:39
	float n_out39p0 = n_out22p0.x;
	float n_out39p1 = n_out22p0.y;


// FloatOp:61
	float n_in61p1 = -1.00000;
	float n_out61p0 = n_out39p1 * n_in61p1;


// FloatOp:38
	float n_out38p0 = atan(n_out39p0, n_out61p0);


// FloatParameter:43
	float n_out43p0 = Skill_Radian_To;


// Compare:47
	bool n_out47p0 = n_out38p0 < n_out43p0;


// FloatParameter:42
	float n_out42p0 = Skill_Radian_From;


// Compare:46
	bool n_out46p0 = n_out38p0 > n_out42p0;


// FloatOp:45
	float n_out45p0 = (n_out47p0 ? 1.0 : 0.0) * (n_out46p0 ? 1.0 : 0.0);


// Compare:24
	bool n_out24p0 = n_out23p0 < n_out32p0;


// Compare:29
	bool n_out29p0 = n_out23p0 > n_out31p0;


// FloatOp:30
	float n_out30p0 = (n_out24p0 ? 1.0 : 0.0) * (n_out29p0 ? 1.0 : 0.0);


// FloatOp:26
	float n_out26p0 = n_out45p0 * n_out30p0;


	vec3 n_out16p0;
// ScreenNormalWorldSpace:16
	{
		vec3 __normals = textureLod(normal_rough_tex_frg_16, SCREEN_UV, 0.0).xyz;
		__normals = __normals * 2.0 - 1.0;
		n_out16p0 = mat3(INV_VIEW_MATRIX) * __normals;
	}


// DotProduct:17
	vec3 n_in17p1 = vec3(0.00000, 1.00000, 0.00000);
	float n_out17p0 = dot(n_out16p0, n_in17p1);


// Compare:19
	float n_in19p1 = 0.10000;
	bool n_out19p0 = n_out17p0 > n_in19p1;


// FloatOp:18
	float n_out18p0 = n_out26p0 * (n_out19p0 ? 1.0 : 0.0);


// FloatOp:50
	float n_out50p0 = n_out49p0 * n_out18p0;


// Clamp:36
	float n_in36p1 = 0.00000;
	float n_in36p2 = 1.00000;
	float n_out36p0 = clamp(n_out50p0, n_in36p1, n_in36p2);


// Output:0
	ALBEDO = vec3(n_out15p0.xyz);
	ALPHA = n_out36p0;


}
